APP_NAME=MentorConnect
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-web-service.koyeb.app
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_KEY=base64:GENERATE_WITH_PHP_ARTISAN_KEY_GENERATE_SHOW

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=YOUR_KOYEB_POSTGRES_HOST
DB_PORT=5432
DB_DATABASE=YOUR_KOYEB_POSTGRES_DATABASE
DB_USERNAME=YOUR_KOYEB_POSTGRES_USER
DB_PASSWORD=YOUR_KOYEB_POSTGRES_PASSWORD
DB_SSLMODE=require

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=YOUR_REVERB_APP_ID
REVERB_APP_KEY=YOUR_REVERB_APP_KEY
REVERB_APP_SECRET=YOUR_REVERB_APP_SECRET

REVERB_HOST=your-reverb-service.koyeb.app
REVERB_PORT=443
REVERB_SCHEME=https

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
